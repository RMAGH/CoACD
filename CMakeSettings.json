{
  "configurations": [
    {
      "name": "x64-Release",
      "generator": "Ninja",
      "configurationType": "RelWithDebInfo",
      "buildRoot": "${projectDir}\\out\\build\\${name}",
      "installRoot": "${projectDir}\\out\\install\\${name}",
      "cmakeCommandArgs": "-DCMAKE_MSVC_RUNTIME_LIBRARY=MultiThreaded",
      "buildCommandArgs": "",
      "ctestCommandArgs": "",
      "inheritEnvironments": [ "msvc_x64_x64" ],
      "variables": [
        {
          "name": "OPENVDB_CORE_SHARED",
          "value": "False",
          "type": "BOOL"
        },
        {
          "name": "CMAKE_CXX_FLAGS",
          "value": "/MT /EHsc",
          "type": "STRING"
        }
      ]
    }
  ]
}